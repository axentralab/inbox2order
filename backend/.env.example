# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Facebook Graph API
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_VERIFY_TOKEN=your-custom-webhook-verify-token

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=your-whatsapp-business-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_VERIFY_TOKEN=your-custom-whatsapp-verify-token

# Steadfast Courier
STEADFAST_API_KEY=your-steadfast-api-key
STEADFAST_API_SECRET=your-steadfast-api-secret
STEADFAST_BASE_URL=https://portal.steadfast.com.bd/api/v1

# Pathao Courier
PATHAO_CLIENT_ID=your-pathao-client-id
PATHAO_CLIENT_SECRET=your-pathao-client-secret
PATHAO_BASE_URL=https://hermes.pathao.com/api/v1
